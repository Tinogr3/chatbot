# Google Cloud Configuration
# Ruta al archivo JSON de credenciales de servicio de Google Cloud
GOOGLE_APPLICATION_CREDENTIALS=TU_RUTA_AL_ARCHIVO_JSON_DE_CREDENCIALES

# ID del proyecto de Google Cloud Platform
PROJECT_ID=TU_PROJECT_ID

GOOGLE_API_KEY=TU_API_KEY_DE_GOOGLE

# Nombre del bucket de Google Cloud Storage donde se almacenarán los archivos PDF
BUCKET_NAME=TU_BUCKET_NAME

VERTEX_AI_API_KEY=TU_API_KEY_DE_VERTEX_AI

# Opcional: Región de Google Cloud (por defecto usará la región del proyecto)
# REGION=us-central1

# Modelo de Vertex AI a utilizar (ej: gemini-2.5-pro, gemini-2.0-flash, gemini-3-pro-preview)
VERTEX_AI_MODEL=gemini-3-pro-preview

# Opcional: Ubicación de ChromaDB (por defecto: ./chroma_db)
# CHROMA_DB_PATH=./chroma_db

RAG_ENABLE_DOCUMENT_CARD=true
RAG_ENABLE_IMAGE_EXTRACTION=true
RAG_MAX_PAGES_FOR_IMAGES=500
RAG_MAX_IMAGES_PER_PDF=50
RAG_VECTOR_BATCH_SIZE=50