# Google Cloud Configuration
# Ruta al archivo JSON de credenciales de servicio de Google Cloud
GOOGLE_APPLICATION_CREDENTIALS=TU_RUTA_AL_ARCHIVO_JSON_DE_CREDENCIALES

# ID del proyecto de Google Cloud Platform
PROJECT_ID=TU_PROJECT_ID

GOOGLE_API_KEY=TU_API_KEY_DE_GOOGLE

# Nombre del bucket de Google Cloud Storage donde se almacenarán los archivos PDF
BUCKET_NAME=TU_BUCKET_NAME

VERTEX_AI_API_KEY=TU_API_KEY_DE_VERTEX_AI

# --- Modelos Gemini (Gemini API). Lista oficial: https://ai.google.dev/gemini-api/docs/models
# Flash (Gemini 3): fichas de documento, extracción de competencias, descripción de imágenes en PDFs.
GEMINI_AI_MODEL_FLASH=gemini-3-flash-preview
# Pro (Gemini 3.1): agente de chat RAG y router de consultas.
GEMINI_AI_MODEL_PRO=gemini-3.1-pro-preview

# Compatibilidad: si GEMINI_AI_MODEL_PRO no está definido, el backend puede usar VERTEX_AI_MODEL.
# VERTEX_AI_MODEL=gemini-3.1-pro-preview

# Opcional: Región de Google Cloud (por defecto usará la región del proyecto)
# REGION=us-central1

# Opcional: Ubicación de ChromaDB (por defecto: ./chroma_db)
# CHROMA_DB_PATH=./chroma_db

RAG_ENABLE_DOCUMENT_CARD=true
RAG_ENABLE_IMAGE_EXTRACTION=true
RAG_MAX_PAGES_FOR_IMAGES=500
RAG_MAX_IMAGES_PER_PDF=50

# Lotes al indexar en Chroma (más alto = menos idas al embedding; más RAM por lote).
RAG_VECTOR_BATCH_SIZE=50

# Hilos en paralelo para describir con Gemini cada imagen extraída del PDF (1–16).
# No reduce cuántas imágenes se extraen; solo acelera las llamadas de visión.
RAG_IMAGE_DESCRIPTION_WORKERS=8

# Procesos Celery concurrentes (cada uno puede estar procesando un PDF). Subir con precaución (RAM/CPU).
CELERY_WORKER_CONCURRENCY=2
# Tareas largas: 1 evita que un worker reserve varios PDFs a la vez.
CELERY_PREFETCH_MULTIPLIER=1